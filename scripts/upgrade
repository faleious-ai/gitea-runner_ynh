#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

upgrade_type=$(ynh_check_app_version_changed)

ynh_script_progression --message="Stopping Gitea Runner..." --weight=1
ynh_systemctl --service="$app" --action="stop" --log_path="systemd" || true

# Older packages stored runtime state beside the binary. Move it into data_dir
# before replacing install_dir so the registered runner identity survives.
for state_file in .runner config.yaml; do
    if [ -f "$install_dir/$state_file" ] && [ ! -f "$data_dir/$state_file" ]; then
        mv "$install_dir/$state_file" "$data_dir/$state_file"
    fi
done

if [ "$upgrade_type" = "UPGRADE_APP" ]; then
    ynh_script_progression --message="Upgrading the Gitea Runner binary..." --weight=2
    ynh_setup_source --dest_dir="$install_dir"
fi

chmod 0755 "$install_dir/runner"
chown -R "$app:$app" "$install_dir" "$data_dir"

if [ ! -f "$data_dir/config.yaml" ]; then
    "$install_dir/runner" generate-config > "$data_dir/config.yaml"
fi
chown "$app:$app" "$data_dir/config.yaml"
chmod 0640 "$data_dir/config.yaml"

ynh_script_progression --message="Refreshing the systemd service..." --weight=1
ynh_config_add_systemd

if [ -f "$data_dir/.runner" ]; then
    yunohost service add "$app" --description="Official Runner for Gitea Actions"
    ynh_script_progression --message="Starting Gitea Runner..." --weight=1
    ynh_systemctl --service="$app" --action="start" --log_path="systemd"
else
    yunohost service remove "$app" >/dev/null 2>&1 || true
    ynh_print_info --message="Upgrade completed without runner identity; service remains inactive."
fi

ynh_script_progression --message="Upgrade of $app completed" --last
