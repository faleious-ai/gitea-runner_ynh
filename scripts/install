#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression --message="Installing the Gitea Runner binary..." --weight=2
ynh_setup_source --dest_dir="$install_dir"
chmod 0755 "$install_dir/runner"
chown -R "$app:$app" "$install_dir" "$data_dir"

ynh_script_progression --message="Creating the Runner configuration..." --weight=1
if [ ! -f "$data_dir/config.yaml" ]; then
    "$install_dir/runner" generate-config > "$data_dir/config.yaml"
fi
chown "$app:$app" "$data_dir/config.yaml"
chmod 0640 "$data_dir/config.yaml"

# Registration is optional so package CI and staged installations do not need
# a live external Gitea instance. A supplied token is consumed once and is not
# stored in YunoHost settings or configuration files.
if [ -n "${token:-}" ]; then
    ynh_script_progression --message="Registering the Runner with Gitea..." --weight=2
    pushd "$data_dir" >/dev/null
    ynh_exec_as_app "$install_dir/runner" --config "$data_dir/config.yaml" register \
        --no-interactive \
        --instance "$gitea_url" \
        --token "$token"
    popd >/dev/null
    token=""
fi

ynh_script_progression --message="Installing the systemd service..." --weight=1
ynh_add_systemd_config

if [ -f "$data_dir/.runner" ]; then
    yunohost service add "$app" \
        --description="Official Runner for Gitea Actions" \
        --log="/var/log/$app/$app.log"
    ynh_script_progression --message="Starting Gitea Runner..." --weight=1
    ynh_systemd_action --service_name="$app" --action="start" --log_path="systemd"
else
    yunohost service remove "$app" >/dev/null 2>&1 || true
    ynh_print_info --message="Runner installed but not registered. Register it from $data_dir, add it to YunoHost service monitoring, then start it."
fi

ynh_script_progression --message="Installation of $app completed" --last
